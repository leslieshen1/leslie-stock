# Tushare Pro token — https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_pro_token_here

# 智谱 GLM API key — https://bigmodel.cn/usercenter/proj-mgmt/apikeys
ZHIPU_API_KEY=your_zhipu_api_key_here
GLM_MODEL=glm-5.1

# Email config (for daily briefing delivery)
# Gmail SMTP: EMAIL_PASSWORD is the *App-Specific Password*, not your Google password
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_FROM=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_TO=your_email@gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
